ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/context_engine
REDIS_URL=redis://localhost:6379/0

# Required. Generate with: openssl rand -base64 32
# Leave empty and scripts/bootstrap.sh will auto-generate one for you.
ENCRYPTION_KEY=

# Host port overrides for docker compose. Uncomment to change what the
# compose file publishes on the host; leave commented to use the defaults.
# HOST_API_PORT=8000
# HOST_POSTGRES_PORT=5432
# HOST_REDIS_PORT=6379

# Optional provider-backed extraction / embeddings. Leave blank to run
# fully offline with the local deterministic embedder + rule extractor —
# this is the default OSS self-hosted path and is what the demo uses.
LITELLM_API_KEY=
LITELLM_API_BASE=
EXTRACTION_MODEL=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=1024

# Optional Zoom OAuth / webhook config.
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=
ZOOM_WEBHOOK_SECRET=

# Optional GitHub API override for self-hosted proxies or gateways.
GITHUB_API_BASE_URL=https://api.github.com

# Optional eval admin token for POST /api/evals/run outside localhost.
EVAL_ADMIN_TOKEN=
