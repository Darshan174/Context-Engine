ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/context_engine
REDIS_URL=redis://localhost:6379/0
ENCRYPTION_KEY=

# Optional provider-backed extraction / embeddings.
LITELLM_API_KEY=
LITELLM_API_BASE=
EXTRACTION_MODEL=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=1024
COHERE_API_KEY=

# Optional Zoom OAuth / webhook config.
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=
ZOOM_WEBHOOK_SECRET=

# Optional GitHub API override for self-hosted proxies or gateways.
GITHUB_API_BASE_URL=https://api.github.com

# Optional eval admin token for POST /api/evals/run outside localhost.
EVAL_ADMIN_TOKEN=
