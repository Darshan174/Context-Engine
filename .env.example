# Context Engine local configuration
# Copy to .env before running the bare-metal or Docker setup paths.

# App and storage
DATABASE_URL=sqlite+aiosqlite:///data/context.db
DATA_DIR=./data
PORT=8000
WORKERS=1
CONTEXT_ENGINE_PROJECT_PATH=.

# Docker PostgreSQL. Change this before any non-local deployment.
POSTGRES_PASSWORD=contextengine

# Optional answer/extraction and embedding models
LITELLM_API_KEY=
EXTRACTION_MODEL=
EMBEDDING_MODEL=
EMBEDDING_DIMENSION=
ENABLE_LOCAL_EMBEDDER=false
ALLOW_HASHING_EMBEDDER=false
PGVECTOR_INDEX_DIMENSION=1024
PGVECTOR_CANDIDATE_LIMIT=200

# Optional API and credential protection
SERVER_API_KEY=
PRINCIPAL_API_KEYS=
API_RATE_LIMIT_PER_MINUTE=0
ENCRYPTION_KEY=
PREVIOUS_ENCRYPTION_KEYS=

# Connector worker
SYNC_WORKER_LEASE_SECONDS=300
SYNC_WORKER_RETRY_BASE_SECONDS=30
SYNC_WORKER_RETRY_MAX_SECONDS=900
SYNC_WORKER_POLL_INTERVAL_SECONDS=2

# Public callback base URL, for example https://context.example.com
PUBLIC_BASE_URL=

# Google OAuth (Gmail and Google Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Slack OAuth
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=
SLACK_MANAGED_INSTALL_URL=

# Zoom remains coming soon; these values are reserved for future support.
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=

# Optional local coding-session locations. Defaults are discovered when blank.
CODEX_HOME=
CLAUDE_HOME=
OPENCODE_HOME=
