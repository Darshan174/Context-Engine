# Context Engine — Caddy reverse-proxy config
#
# Caddy is the fastest path to a production self-hosted deployment. It
# handles HTTPS certificate provisioning, renewal, and redirects from
# HTTP → HTTPS automatically. Zero manual cert management.
#
# ──────────────────────────────────────────────────────────────────────
# How to use
# ──────────────────────────────────────────────────────────────────────
# 1. Replace `context-engine.example.com` below with your real domain.
# 2. Copy this file to /etc/caddy/Caddyfile on the VPS:
#
#      sudo cp deploy/caddy/Caddyfile /etc/caddy/Caddyfile
#      sudo systemctl reload caddy
#
# 3. Point your DNS A/AAAA record at the VPS. Caddy will auto-issue a
#    Let's Encrypt cert on first request.
# 4. Verify:
#      curl -sS https://context-engine.example.com/health
#
# ──────────────────────────────────────────────────────────────────────
# Prerequisites
# ──────────────────────────────────────────────────────────────────────
# - Caddy 2.x installed (apt install caddy on Debian/Ubuntu).
# - The API bound to 127.0.0.1:8000 (the default in docker-compose.yml).
# - Port 80 and 443 open on the host firewall (ufw allow 80,443/tcp).
# - DNS configured so the domain resolves to this host — required for
#   Let's Encrypt HTTP-01 / TLS-ALPN-01 challenges.

context-engine.example.com {
    # Reverse-proxy everything to the API container on 127.0.0.1:8000.
    reverse_proxy 127.0.0.1:8000 {
        # Pass the original client IP and scheme so FastAPI can log them.
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}

        # Long-poll friendly — Context Engine doesn't have websockets
        # today but the query endpoint can take 10-30 s on provider-
        # backed extraction. Bump the proxy read timeout accordingly.
        transport http {
            read_timeout 120s
            write_timeout 120s
        }
    }

    # Security headers. Safe defaults for an API-first service.
    header {
        # HSTS — 1 year, include subdomains. Uncomment once you are
        # confident the domain is committed to HTTPS only. DO NOT
        # enable until you have verified the cert renews automatically.
        # Strict-Transport-Security "max-age=31536000; includeSubDomains"

        # Prevent clickjacking / content-type sniffing.
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"

        # Context Engine does not serve mixed content — remove the
        # default Server header for a smaller attack-surface signal.
        -Server
    }

    # Structured logs — one line per request, easy to ship to Loki/Vector.
    log {
        output file /var/log/caddy/context-engine.log {
            roll_size 50mb
            roll_keep 5
        }
        format json
        level INFO
    }

    # ──────────────────────────────────────────────────────────────────
    # Optional: basic auth (uncomment if the API is not yet behind a
    # real identity provider). Generate a password hash with:
    #   caddy hash-password --plaintext 'your-password'
    # Then put the resulting hash below.
    # ──────────────────────────────────────────────────────────────────
    # basicauth /* {
    #     founder  $2a$14$REPLACE_WITH_HASH
    # }

    # ──────────────────────────────────────────────────────────────────
    # Optional: IP allow-list. Uncomment and add your office/VPN IPs
    # to restrict all access to known networks. Combine with basicauth
    # or a tunnel (Tailscale, Cloudflare Access) for defense in depth.
    # ──────────────────────────────────────────────────────────────────
    # @allowed {
    #     remote_ip 203.0.113.0/24 198.51.100.42
    # }
    # handle @allowed {
    #     reverse_proxy 127.0.0.1:8000
    # }
    # handle {
    #     respond 403
    # }
}

# ──────────────────────────────────────────────────────────────────────
# Optional: redirect an apex domain to the www subdomain (or vice versa)
# ──────────────────────────────────────────────────────────────────────
# example.com {
#     redir https://context-engine.example.com{uri} permanent
# }
